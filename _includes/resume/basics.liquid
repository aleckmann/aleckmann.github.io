<table>
    {% assign skipped_categories = "image,profiles,location" | split: ',' %}
    {% for content in section[1] %}
        {% if (content[1] == "") or (skipped_categories contains content[0]) %}
            {% continue %}
        {% endif %}
        <tr>
            <td>
                <b>{{content[0] | capitalize}}</b>
            </td>
            <td>
            {% if content[0] == 'url' or content[0] == 'website' %}
                <a href="{{ content[1] }}" target="_blank" rel="noopener noreferrer">{{ content[1] }}</a>
            {% elsif content[0] == 'email' %}
                <a href="mailto:{{ content[1] }}" target="_blank">{{ content[1] }}</a>
            {% elsif content[0] == 'phone' %}
                <a href="tel:{{ content[1] }}">{{ content[1] }}</a>
            {% else %}
                {{ content[1] }}
            {% endif %}
            </td>
        </tr>
    {% endfor %}
</table>