---
layout: default
---
<div>
  {% comment %}
  page title and description in header, rendered as topmost text
  {% endcomment %}
  <header>
    {%comment%} <h1>{{ page.title }}</h1> {%endcomment%}
    {% if page.description %}
    <p class="post-description">{{ page.description }}</p>
    {% endif %}
  </header>

  {% comment %}
  - actual resume content sourced from assets/json/resume.json (hardcoded path)
  - jsonresume schema: https://jsonresume.org/schema
  - all resume rendering are versions of https://github.com/alshedivat/al-folio/tree/main/_includes/resume that have
  been modified to fit the theme
  {% endcomment %}
  <article>
    {% for section in site.data.resume %}
    {% if section[0] contains "example" %}
    {% continue %}
    {% endif %}
    <h2>{{section[0] | capitalize}}</h2>
    <div>
      {% case section[0] %}
      {% when 'basics' %}
      {% include resume/basics.liquid %}
      {% when 'education' %}
      {% include resume/education.liquid %}
      {% when 'work' %}
      {% include resume/work.liquid %}
      {% comment %}
      {% when 'volunteer' %}
      {% include resume/volunteer.liquid %}
      {% when 'projects' %}
      {% include resume/projects.liquid %}
      {% when 'awards' %}
      {% include resume/awards.liquid %}
      {% when 'skills' %}
      {% include resume/skills.liquid %}
      {% when 'publications' %}
      {% include resume/publications.liquid %}
      {% when 'languages' %}
      {% include resume/languages.liquid %}
      {% when 'interests' %}
      {% include resume/interests.liquid %}
      {% when 'certificates' %}
      {% include resume/certificates.liquid %}
      {% when 'references' %}
      {% include resume/references.liquid %}
      {% endcomment %}
      {% else %}

      {% endcase %}
    </div>
    {% endfor %}
  </article>
</div>